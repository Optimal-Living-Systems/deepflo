# DeepFlow Configuration
# Copy this file to .env and fill in your values.

# ─── Required: At least one LLM provider API key ─────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── DeepFlow Runtime Settings ────────────────────────────────
# Model identifier (format: provider:model-name)
DEEPFLOW_MODEL=anthropic:claude-sonnet-4-20250514

# Runtime server port
DEEPFLOW_PORT=8100

# Maximum agent loop iterations per request
DEEPFLOW_MAX_STEPS=50

# Request timeout in seconds
DEEPFLOW_TIMEOUT=300

# Logging level (DEBUG, INFO, WARNING, ERROR)
DEEPFLOW_LOG_LEVEL=INFO

# ─── Langflow Settings (Docker only) ─────────────────────────
LANGFLOW_PORT=7860

# ─── Optional: LangSmith Tracing ─────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=deepflow
